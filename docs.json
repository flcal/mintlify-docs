{
  "$schema": "https://mintlify.com/docs.json",

  "theme": "sequoia",
  "name": "Mintlify Starter Kit",

  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },

  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },

  "favicon": "/favicon.svg",

  "background": {
    "decoration": "windows",
    "color": {
      "light": "#F0EEE9",
      "dark": "#111111"
    }
  },

  "icons": {
    "library": "lucide"
  },

  "navbar": {
    "tabs": [
      {
        "tab": "Developer tools",
        "icon": "terminal",
        "menu": [
          {
            "item": "API reference",
            "icon": "rocket",
            "groups": [
              {
                "group": "Core endpoints",
                "icon": "terminal",
                "pages": [
                  "api-reference/get",
                  "api-reference/post",
                  "api-reference/delete"
                ]
              }
            ]
          },
          {
            "item": "SDKs",
            "icon": "code",
            "description": "SDKs for interacting with the API.",
            "pages": [
              "sdk/fetch",
              "sdk/create",
              "sdk/delete"
            ]
          }
        ]
      }
    ],

    "anchors": [
      {
        "anchor": "Documentation",
        "icon": "book",
        "pages": [
          "quickstart",
          "development",
          "navigation"
        ]
      },
      {
        "anchor": "API reference",
        "icon": "terminal",
        "pages": [
          "api-reference/get",
          "api-reference/post",
          "api-reference/delete"
        ]
      },
      {
        "anchor": "Blog",
        "href": "https://external-link.com/blog"
      }
    ],

    "links": [
      {
        "href": "mailto:hi@mintlify.com",
        "label": "Support"
      },
      {
        "href": "/",
        "label": "Get started"
      },
      {
        "href": "/",
        "label": "About"
      }
    ],

    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.mintlify.com"
    }
  },

  "footer": {
    "socials": {
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    },
    "links": [
      {
        "header": "Social",
        "items": [
          {
            "label": "Git",
            "href": "https://github.com/mintlify"
          },
          {
            "label": "X",
            "href": "https://x.com"
          }
        ]
      },
      {
        "header": "Website",
        "items": [
          {
            "label": "About",
            "href": "/about"
          },
          {
            "label": "Legal",
            "href": "/legal"
          }
        ]
      }
    ]
  },

  "fonts": {
    "family": "Inter",
    "weight": 300
  },

  "styling": {
    "eyebrows": "breadcrumbs",
    "latex": false
  },

  "banner": {
    "content": "Now live!",
    "dismissible": true,
    "color": {
      "light": "#e6a1a1",
      "dark": "#3a2f2f"
    }
  },

  "errors": {
    "404": {
      "redirect": false
    }
  },

  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity"
    ],
    "display": "toc"
  },

  "interaction": {
    "drilldown": false
  },

  "metadata": {
    "timestamp": false
  },

  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "icon": "book",
          "href": "https://mintlify.com/docs"
        },
        {
          "anchor": "Blog",
          "icon": "newspaper",
          "href": "https://mintlify.com/blog"
        }
      ]
    },

    "pages": [
      {
        "group": "Getting Started",
        "pages": [
          "index",
          "quickstart"
        ]
      }
    ]
  }
}
