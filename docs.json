{
  "theme": "sequoia",
  "name": "Mintlify Starter Kit",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/favicon.svg",
  "background": {
    "decoration": "windows",
    "color": {
      "light": "#F0EEE9",
      "dark": "#111111"
    }
  },
  "navbar": {
    "links": [
      {
        "href": "mailto:hi@mintlify.com",
        "label": "Support"
      },
      {
        "href": "/logo",
        "label": "Get started"
      },
      {
        "href": "/logo",
        "label": "About"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.mintlify.com"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    },
    "links": [
      {
        "header": "Social",
        "items": [
          {
            "label": "Git",
            "href": "/logo"
          },
          {
            "label": "X",
            "href": "/logo"
          },
          {
            "label": "Sozial",
            "href": "/logo"
          }
        ]
      },
      {
        "header": "Website",
        "items": [
          {
            "label": "About",
            "href": "/logo"
          },
          {
            "label": "Legal",
            "href": "/logo"
          }
        ]
      }
    ]
  },
  "fonts": {
    "family": "Inter",
    "weight": 300
  },
  "icons": {
    "library": "fontawesome"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "latex": false
  },
  "banner": {
    "content": "Now on!",
    "dismissible": true,
    "color": {
      "light": "#e6a1a1",
      "dark": "#3a2f2f"
    }
  },
  "errors": {
    "404": {
      "redirect": false
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ],
    "display": "toc"
  },
  "interaction": {
    "drilldown": true
  },
  "metadata": {
    "timestamp": false
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "icon": "book-open-cover",
          "href": "https://mintlify.com/docs"
        },
        {
          "anchor": "Blog",
          "icon": "newspaper",
          "href": "https://mintlify.com/blog"
        }
      ]
    },
    "pages": [
      {
        "group": "Getting Started",
        "pages": [
          "index",
          "quickstart"
        ]
      },
      {
        "group": "Getting Started",
        "pages": [
          "index",
          "quickstart"
        ]
      },
      "titelpage"
    ]
  }
}
